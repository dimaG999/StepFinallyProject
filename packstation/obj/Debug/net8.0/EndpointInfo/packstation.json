  "components": {
    "schemas": {
      "CategoryCreateDto": {
        "required": [
          "categoryName"
        ],
        "type": "object",
        "properties": {
          "categoryName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "parcelCategoryId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CategoryUpdateDto": {
        "required": [
          "categoryName"
        ],
        "type": "object",
        "properties": {
          "categoryName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "parcelCategoryId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "LogInDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ParcelCreateDto": {
        "required": [
          "destinationAddress",
          "sendingNumber",
          "userEmail"
        ],
        "type": "object",
        "properties": {
          "sendingNumber": {
            "minLength": 1,
            "pattern": "^\\d{5}$",
            "type": "string"
          },
          "userEmail": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "destinationAddress": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "parcelCategoryId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ParcelStatus": {
        "enum": [
          0,
          1,
          2,
          3,
          4
        ],
        "type": "integer",
        "format": "int32"
      },
      "ParcelUpdateDto": {
        "required": [
          "destinationAddress",
          "parcelCategoryId",
          "sendingNumber"
        ],
        "type": "object",
        "properties": {
          "sendingNumber": {
            "minLength": 1,
            "pattern": "^\\d{5}$",
            "type": "string"
          },
          "parcelCategoryId": {
            "type": "integer",
            "format": "int32"
          },
          "destinationAddress": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "parcelStatus": {
            "$ref": "#/components/schemas/ParcelStatus"
          }
        },
        "additionalProperties": false
      },
      "UserCreateDto": {
        "required": [
          "email",
          "role",
          "userLastName",
          "userName"
        ],
        "type": "object",
        "properties": {
          "userName": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "userLastName": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "$ref": "#/components/schemas/UserRole"
          }
        },
        "additionalProperties": false
      },
      "UserRole": {
        "enum": [
          0,
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "UserUpdateDto": {
        "required": [
          "role",
          "userLastName",
          "userName"
        ],
        "type": "object",
        "properties": {
          "userName": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "userLastName": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/UserRole"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "Enter 'Bearer' [space] and then your valid token in the text input below.\r\nExample: \"Bearer eyJhbGciOiJIUzI1NiIs...\"",
        "name": "Authorization",
        "in": "header"
      }
    }
